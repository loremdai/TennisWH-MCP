{
  "openapi": "3.1.0",
  "info": {
    "title": "Tennis Warehouse API",
    "description": "Search tennis products from Tennis Warehouse - racquets, shoes, bags, deals and more.",
    "version": "v1.0.0"
  },
  "servers": [
    {
      "url": "https://tennis-wherehouse-mcp-production.up.railway.app",
      "description": "Production server"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "description": "Search tennis products with intelligent filtering",
        "operationId": "searchTennisProducts",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search term for tennis products (e.g., 'wilson racquet', 'nike shoes', 'tennis balls')",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of results to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 20
            }
          }
        ],
        "deprecated": false
      }
    },
    "/smart-search": {
      "get": {
        "description": "Intelligent search with conversational filtering options and suggestions",
        "operationId": "smartSearchTennis",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search term for tennis products",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of results to analyze",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 50
            }
          }
        ],
        "deprecated": false
      }
    },
    "/racquets": {
      "get": {
        "description": "Search specifically for tennis racquets with brand filtering",
        "operationId": "searchTennisRacquets",
        "parameters": [
          {
            "name": "brand",
            "in": "query",
            "description": "Racquet brand (e.g., 'Wilson', 'Babolat', 'Head', 'Yonex')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of results",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 20
            }
          }
        ],
        "deprecated": false
      }
    },
    "/shoes": {
      "get": {
        "description": "Search for tennis shoes with gender and brand filtering",
        "operationId": "searchTennisShoes",
        "parameters": [
          {
            "name": "gender",
            "in": "query",
            "description": "Target gender (men, women, unisex)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["men", "women", "unisex"]
            }
          },
          {
            "name": "brand",
            "in": "query",
            "description": "Shoe brand (e.g., 'Nike', 'Adidas', 'Asics')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of results",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 20
            }
          }
        ],
        "deprecated": false
      }
    },
    "/bags": {
      "get": {
        "description": "Search for tennis bags with style and brand filtering",
        "operationId": "searchTennisBags",
        "parameters": [
          {
            "name": "style",
            "in": "query",
            "description": "Bag style (e.g., 'backpack', 'tote', 'duffel', '6 pack', '12 pack')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "brand",
            "in": "query",
            "description": "Brand filter (e.g., 'Wilson', 'Head', 'Babolat')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of results",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 20
            }
          }
        ],
        "deprecated": false
      }
    },
    "/deals": {
      "get": {
        "description": "Find current deals and discounted tennis products",
        "operationId": "getTennisDeals",
        "parameters": [
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of deals to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 20
            }
          }
        ],
        "deprecated": false
      }
    },
    "/availability": {
      "get": {
        "description": "Check if a specific tennis product is in stock",
        "operationId": "checkProductAvailability",
        "parameters": [
          {
            "name": "product_name",
            "in": "query",
            "description": "Exact or partial product name to check availability for",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "deprecated": false
      }
    },
    "/categories": {
      "get": {
        "description": "Get all available tennis product categories",
        "operationId": "getTennisCategories",
        "parameters": [],
        "deprecated": false
      }
    }
  },
  "components": {
    "schemas": {
      "TennisProduct": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "brand": {
            "type": "string",
            "description": "Product brand"
          },
          "price": {
            "type": "string",
            "description": "Product price"
          },
          "availability": {
            "type": "string",
            "description": "Availability status"
          },
          "product_url": {
            "type": "string",
            "description": "Link to product on Tennis Warehouse"
          },
          "source_citation": {
            "type": "string",
            "description": "Citation link to Tennis Warehouse"
          }
        }
      }
    }
  }
}
